# ============================
# OpenClaw Host Bootstrap Env
# 位置建议：/opt/openclaw/bootstrap.env
# 权限建议：chmod 600
# ============================

# --- 基础身份/系统 ---
ADMIN_USER="op"
TIMEZONE="America/Los_Angeles"
HOSTNAME_FQDN="openclaw-1"
SSH_PORT="22"

# 你的 SSH 公钥（不是私钥）。示例：ssh-ed25519 AAAA... comment
# 强烈建议：给这台服务器单独生成一对 key
SSH_PUBKEY="ssh-ed25519 AAAA...REPLACE_ME... linode-openclaw"

# --- OpenClaw 目录 ---
OPENCLAW_BASE="/opt/openclaw"

# --- Infra（pgvector + valkey）初始化参数 ---
POSTGRES_DB="openclaw"
POSTGRES_USER="openclaw"
POSTGRES_PASSWORD="CHANGE_ME_STRONG"   # 这是敏感信息：只放服务器，不入库

# pgvector 镜像（pg18-trixie 是目前 pgvector/pgvector 的 Postgres 18 系标签之一）:contentReference[oaicite:3]{index=3}
PGVECTOR_IMAGE="pgvector/pgvector:pg18-trixie"

# Valkey 版本线：9.x（示例 9.0.3）:contentReference[oaicite:4]{index=4}
VALKEY_IMAGE="valkey/valkey:9"

# --- 资源默认（可覆盖）---
# 4GB/8GB wrapper 会给合理默认；你也可以在这里强制覆盖
# SWAP_GB="2"
# POSTGRES_MEM_LIMIT="1100m"
# VALKEY_MEM_LIMIT="256m"
# VALKEY_MAXMEM="192mb"

# --- Cloudflare Tunnel（单 Web 后台，不需要反代）---
CF_RUN_USER="op"                      # 用哪个用户执行 cloudflared login/create
CF_TUNNEL_NAME="openclaw-admin"
CF_HOSTNAME="admin.example.com"
CF_LOCAL_URL="http://127.0.0.1:3000"  # 你的 Web 后台务必只监听 127.0.0.1
